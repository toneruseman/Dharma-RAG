# =============================================================================
# Dharma RAG — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- LLM Provider (required) ---
# OpenRouter is the primary gateway (one key for many models — Anthropic, Google,
# DeepSeek, etc). Used by Contextual Retrieval (rag-day-16+) and future LLM
# generation (rag-day-22+). Get a key at https://openrouter.ai.
OPENROUTER_API_KEY=sk-or-v1-...

# Direct Anthropic — optional fallback (only used if you bypass OpenRouter).
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional LLM fallbacks ---
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# --- Contextual Retrieval (rag-day-16+) ---
# Model used by scripts/contextualize_corpus.py — anything OpenRouter routes to
# that supports Anthropic-style cache_control or implicit caching.
CONTEXT_MODEL=anthropic/claude-3.5-haiku

# --- Embedding API (optional, for evaluation) ---
VOYAGE_API_KEY=pa-...
COHERE_API_KEY=...

# --- Transcription (Phase 2) ---
GROQ_API_KEY=gsk_...

# --- Voice (Phase 3) ---
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...
LIVEKIT_URL=wss://your-project.livekit.cloud

# --- Vector DB ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # empty for local

# --- Application Database (Postgres for FRBR corpus + app tables) ---
DHARMA_DB_PASSWORD=dharma_dev
DATABASE_URL=postgresql+asyncpg://dharma:dharma_dev@localhost:5432/dharma  # pragma: allowlist secret

# --- Observability ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# --- App Configuration ---
APP_ENV=development  # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DEBUG=true

# --- Models ---
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ROUTER_LLM=claude-haiku-4-5-20251001
DEFAULT_LLM=claude-sonnet-4-6
COMPLEX_LLM=claude-opus-4-6

# --- Retrieval ---
RETRIEVAL_TOP_K=100
RERANK_TOP_K=10
HYBRID_DENSE_WEIGHT=0.6
HYBRID_SPARSE_WEIGHT=0.4
SEMANTIC_CACHE_THRESHOLD=0.92

# --- Telegram Bot (Phase 1.5) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=  # comma-separated user IDs, or empty for public

# --- Storage paths ---
DATA_DIR=./data
QDRANT_STORAGE=./qdrant_storage
LOGS_DIR=./logs
