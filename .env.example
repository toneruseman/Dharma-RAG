# =============================================================================
# Dharma RAG — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- LLM Provider (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional LLM fallbacks ---
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# --- Embedding API (optional, for evaluation) ---
VOYAGE_API_KEY=pa-...
COHERE_API_KEY=...

# --- Transcription (Phase 2) ---
GROQ_API_KEY=gsk_...

# --- Voice (Phase 3) ---
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...
LIVEKIT_URL=wss://your-project.livekit.cloud

# --- Vector DB ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # empty for local

# --- Observability ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# --- App Configuration ---
APP_ENV=development  # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DEBUG=true

# --- Models ---
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ROUTER_LLM=claude-haiku-4-5-20251001
DEFAULT_LLM=claude-sonnet-4-6
COMPLEX_LLM=claude-opus-4-6

# --- Retrieval ---
RETRIEVAL_TOP_K=100
RERANK_TOP_K=10
HYBRID_DENSE_WEIGHT=0.6
HYBRID_SPARSE_WEIGHT=0.4
SEMANTIC_CACHE_THRESHOLD=0.92

# --- Telegram Bot (Phase 1.5) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=  # comma-separated user IDs, or empty for public

# --- Storage paths ---
DATA_DIR=./data
QDRANT_STORAGE=./qdrant_storage
LOGS_DIR=./logs
