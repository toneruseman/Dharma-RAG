# Ignore ML model artefacts anywhere in the tree, but keep our ORM
# model source under version control. __pycache__ is still ignored
# via the global rule above.
models/
!src/db/models/
!src/db/models/*.py

# Logs
*.log
logs/
langfuse_data/

# Notebooks
.ipynb_checkpoints/
*.ipynb

# Eval results (keep structure, ignore content)
tests/eval/results/*.json
tests/eval/eval_corpus.jsonl

# Docker
.docker/

# OS
Thumbs.db
desktop.ini

# Secrets
secrets/
*.pem
*.key

# Generated PDF exports (from scripts/md_to_pdf.py)
docs/pdf/
docs/old/pdf/
*.pdf

# Obsidian vault config — per-user settings, plugins, workspace state.
# Vault root is `docs/`; the .obsidian/ folder there is local to whoever
# opens the docs in Obsidian.
docs/.obsidian/

# Claude Code harness — project agents are SHARED (committed),
# but user-local overrides and cache are personal.
.claude/settings.local.json
.claude/.cache/
.claude/*.log

# Node / pnpm (app-track, app-day-01+)
node_modules/
.pnpm-store/
web/.next/
web/out/
web/next-env.d.ts
*.tsbuildinfo

# Pāli glossary raw downloads (rag-day-23) — 15 MB of .mjs from ms-dpd
# that we re-parse on demand via scripts/build_dpd_glossary.py. The
# parsed JSON (data/glossary/dpd_full.json, 10 MB) and the manual
# cyrillic layer (data/glossary/cyrillic.yaml) ARE committed.
data/glossary/dpd_raw/

# Per-run model comparisons (rag-day-24) — generated by
# scripts/compare_answer_models.py. They're useful one-off artifacts,
# not stable references. Commit specific ones manually if needed.
docs/MODEL_COMPARISON_*.md
